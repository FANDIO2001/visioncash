################################################################################
# VisionCash - Personal Finance Management API
# Environment Configuration Template
# Copy this file to .env and fill in your actual values
################################################################################

# Application Settings
APP_NAME="VisionCash"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

# Localization
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file

# Security
BCRYPT_ROUNDS=12

################################################################################
# DATABASE CONFIGURATION
################################################################################

# Development (SQLite)
DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

# Production (MySQL) - Uncomment and configure
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=visioncash
# DB_USERNAME=root
# DB_PASSWORD=

# Production (PostgreSQL) - Alternative option
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=visioncash
# DB_USERNAME=postgres
# DB_PASSWORD=

################################################################################
# CACHE & SESSION CONFIGURATION
################################################################################

CACHE_DRIVER=file
CACHE_PREFIX=visioncash_

QUEUE_CONNECTION=sync

SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=

################################################################################
# AUTHENTICATION & API
################################################################################

AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173
SANCTUM_GUARD=web

################################################################################
# MAIL CONFIGURATION
################################################################################

# Development (Log driver - emails printed to logs)
MAIL_MAILER=log

# Production (SMTP)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=your_username
# MAIL_PASSWORD=your_password
# MAIL_ENCRYPTION=tls

MAIL_FROM_ADDRESS="noreply@visioncash.local"
MAIL_FROM_NAME="${APP_NAME}"

################################################################################
# LOGGING
################################################################################

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################################################################
# AWS S3 CONFIGURATION (Optional)
################################################################################

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=visioncash-uploads
# AWS_USE_PATH_STYLE_ENDPOINT=false

################################################################################
# REDIS CONFIGURATION (Optional - for cache/sessions in production)
################################################################################

# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# REDIS_CACHE_DB=1

################################################################################
# THIRD-PARTY PAYMENT SERVICES
################################################################################

# Stripe (Optional)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (Optional)
# PAYPAL_MODE=sandbox
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

# Square (Optional)
# SQUARE_ACCESS_TOKEN=
# SQUARE_ENVIRONMENT=sandbox

################################################################################
# BANKING INTEGRATIONS (Optional)
################################################################################

# Plaid (Bank connections)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_COUNTRY_CODES=US

################################################################################
# NOTIFICATION SERVICES
################################################################################

# Twilio (SMS)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+1234567890

# Firebase (Push Notifications)
# FCM_SERVER_KEY=
# FCM_PROJECT_ID=

# SendGrid (Email - Alternative)
# SENDGRID_API_KEY=

################################################################################
# FILE STORAGE
################################################################################

FILESYSTEM_DISK=local
FILESYSTEM_VISIBILITY=private

# For AWS S3:
# FILESYSTEM_DISK=s3
# FILESYSTEM_VISIBILITY=private

################################################################################
# APPLICATION FEATURES & DEFAULTS
################################################################################

# Currency & Localization
DEFAULT_CURRENCY=USD
DEFAULT_LANGUAGE=en
DATE_FORMAT=Y-m-d
TIME_FORMAT=H:i:s

# Feature Flags (Enable/disable features)
FEATURE_MFA_ENABLED=true
FEATURE_CSV_IMPORT=true
FEATURE_INTEGRATIONS=true
FEATURE_RECURRING_TRANSACTIONS=true
FEATURE_BUDGETS=true
FEATURE_NOTIFICATIONS=true
FEATURE_SUBSCRIPTIONS=true
FEATURE_REPORTS=true

################################################################################
# SECURITY SETTINGS
################################################################################

# API Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_PERIOD=60

# Login & Session
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
SESSION_TIMEOUT=3600
TOKEN_EXPIRY_DAYS=30

# MFA
MFA_TOKEN_EXPIRY=300

# CORS
CORS_ALLOWED_ORIGINS=*

################################################################################
# DEVELOPMENT & DEBUGGING
################################################################################

# Laravel Debugbar
DEBUGBAR_ENABLED=true

# Laravel Telescope
TELESCOPE_ENABLED=false

# Query Logging
QUERY_LOGGING=false

# Sentry (Error tracking - Optional)
# SENTRY_LARAVEL_DSN=
# SENTRY_RELEASE=

################################################################################
# DEPLOYMENT
################################################################################

# Production - Set these for security
# APP_ENV=production
# APP_DEBUG=false
# CACHE_DRIVER=redis
# QUEUE_CONNECTION=redis

SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
